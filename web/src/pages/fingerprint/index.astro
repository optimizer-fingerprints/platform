---
import Layout from '../../layouts/Layout.astro';
import { loadFingerprints } from '../../lib/data';

const fingerprints = loadFingerprints().map((entry) => ({ full: entry.full }));
---

<Layout title="Fingerprint">
	<section class="fingerprint-shell" data-fingerprint-root>
		{
			fingerprints.length === 0 ? (
				<div class="empty">No current-schema fingerprints are available.</div>
			) : (
				<>
					<header class="fingerprint-topbar">
						<div class="run-meta" data-run-meta></div>
						<div class="field">
							<label for="fingerprint-select">Fingerprint</label>
							<select id="fingerprint-select" data-fingerprint-select>
								{fingerprints.map(({ full }, index) => (
									<option value={String(index)}>
										{full.optimizer.name} / {full.task.id} / seed {full.task.seed}
									</option>
								))}
							</select>
						</div>
					</header>

					<div class="pane-frame">
						<div class="pane-inner">
							<section class="relative-pane">
								<div class="selector-bar">
									<h2 class="selector-title">Relative Update Geometry</h2>
									<div class="selector-controls">
										<div class="field">
											<label class="sr-only" for="parameter-set-select">Parameter set</label>
											<select id="parameter-set-select" data-parameter-set-select>
												<option value="conv_weights">conv weights</option>
												<option value="conv_biases">conv biases</option>
												<option value="batchnorm_weights">batchnorm weights</option>
												<option value="batchnorm_biases">batchnorm biases</option>
												<option value="all_weights">all weights</option>
												<option value="all_biases">all biases</option>
												<option value="layer1">layer1</option>
												<option value="layer2">layer2</option>
												<option value="layer3">layer3</option>
												<option value="layer4">layer4</option>
												<option value="downsample">downsample</option>
												<option value="fc">fc</option>
												<option value="custom">custom</option>
											</select>
										</div>
										<button type="button" data-custom-edit>Edit custom</button>
										<div class="set-summary" data-set-summary></div>
									</div>
								</div>

								<div class="chart-stack" data-chart-stack></div>
							</section>
						</div>
					</div>

					<div class="custom-modal" data-custom-modal aria-hidden="true">
						<div class="custom-dialog">
							<header>
								<h2>Custom Parameters</h2>
								<button type="button" data-custom-close aria-label="Close custom parameter picker">x</button>
							</header>
							<div class="custom-tools">
								<div class="field">
									<label for="custom-filter">Filter</label>
									<input id="custom-filter" type="search" placeholder="conv2, layer3, bias..." data-custom-filter />
								</div>
								<div class="custom-actions">
									<button type="button" data-custom-select-visible>Select visible</button>
									<button type="button" data-custom-clear>Clear</button>
									<button type="button" data-custom-apply>Apply</button>
								</div>
							</div>
							<div class="custom-count" data-custom-count></div>
							<div class="custom-list" data-custom-list></div>
						</div>
					</div>
				</>
			)
		}
	</section>
</Layout>

<style is:global>
	.fingerprint-shell {
		box-sizing: border-box;
		padding: 10px 28px 0;
	}

	.fingerprint-shell *,
	.fingerprint-shell *::before,
	.fingerprint-shell *::after {
		box-sizing: border-box;
	}

	.fingerprint-shell .sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
	}

	.fingerprint-topbar {
		display: flex;
		gap: 12px;
		align-items: flex-start;
		justify-content: space-between;
		margin-bottom: 12px;
	}

	.fingerprint-topbar > .field {
		flex: 0 1 360px;
		min-width: 260px;
	}

	.run-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		font-family: var(--sans);
	}

	.run-meta span {
		border: 1px solid var(--line);
		padding: 2px 7px;
		background: var(--paper);
		color: var(--muted);
		font-size: 11px;
	}

	.relative-pane {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.selector-bar {
		display: flex;
		gap: 14px;
		align-items: center;
		justify-content: space-between;
		border-bottom: 1px solid var(--line);
		padding: 0 12px 10px;
	}

	.selector-title {
		margin: 0;
		color: var(--ink);
		font-family: var(--sans);
		font-size: 20px;
		font-weight: 600;
		letter-spacing: 0;
		line-height: 1.2;
		white-space: nowrap;
	}

	.selector-controls {
		display: flex;
		gap: 10px;
		align-items: center;
		justify-content: flex-end;
		min-width: 0;
	}

	.selector-bar .field {
		width: min(300px, 32vw);
		min-width: 220px;
	}

	.selector-bar button,
	.scale-toggle button,
	.custom-dialog button {
		min-height: 34px;
		border: 1px solid var(--line-strong);
		background: var(--paper);
		color: var(--ink);
		padding: 6px 9px;
		font-family: var(--sans);
		font-size: 12px;
		cursor: pointer;
		white-space: nowrap;
	}

	.scale-toggle button[aria-pressed='true'] {
		background: var(--accent-soft);
		font-weight: 600;
	}

	.set-summary,
	.chart-note,
	.custom-count {
		color: var(--muted);
		font-family: var(--sans);
		font-size: 12px;
	}

	.set-summary {
		white-space: nowrap;
	}

	.chart-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.chart-card {
		flex: 1 1 calc(50% - 6px);
		min-width: 320px;
		background: var(--paper);
	}

	.chart-card > header {
		display: flex;
		gap: 12px;
		align-items: flex-start;
		justify-content: space-between;
		padding: 10px 12px;
		font-family: var(--sans);
	}

	.chart-card > header > div:first-child {
		flex: 1 1 auto;
		min-width: 0;
	}

	.chart-card h3 {
		margin: 0;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.chart-subtitle {
		margin-top: 4px;
		color: var(--muted);
		font-size: 11px;
	}

	.scale-toggle {
		display: inline-flex;
		gap: 4px;
	}

	.main-chart {
		height: 220px;
		min-height: 220px;
	}

	.main-chart > div {
		width: 100%;
		height: 100%;
	}

	.custom-modal {
		position: fixed;
		inset: 0;
		z-index: 30;
		display: none;
		background: rgb(31 27 22 / 0.25);
	}

	.custom-modal[aria-hidden='false'] {
		display: block;
	}

	.custom-dialog {
		position: absolute;
		top: 40px;
		left: 50%;
		width: min(720px, calc(100vw - 32px));
		max-height: calc(100vh - 80px);
		overflow: auto;
		transform: translateX(-50%);
		border: 1px solid var(--line-strong);
		background: var(--paper);
		padding: 16px;
	}

	.custom-dialog > header {
		display: flex;
		justify-content: space-between;
		gap: 16px;
		border-bottom: 1px solid var(--line);
		padding-bottom: 10px;
	}

	.custom-dialog h2 {
		margin: 0;
		font-family: var(--sans);
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.custom-tools {
		display: flex;
		gap: 12px;
		align-items: flex-end;
		margin-top: 12px;
	}

	.custom-tools .field {
		flex: 1 1 220px;
		min-width: 220px;
	}

	.custom-actions {
		display: flex;
		gap: 8px;
	}

	.custom-list {
		display: flex;
		flex-wrap: wrap;
		max-height: 460px;
		overflow: auto;
		border: 1px solid var(--line);
		margin-top: 10px;
		font-family: var(--sans);
		font-size: 12px;
	}

	.custom-option {
		display: flex;
		flex: 1 1 50%;
		gap: 7px;
		align-items: flex-start;
		min-width: min(320px, 100%);
		border-bottom: 1px solid var(--line);
		padding: 7px;
		cursor: pointer;
	}

	.custom-option input {
		flex: 0 0 auto;
	}

	.custom-option span {
		overflow-wrap: anywhere;
		font-family: var(--mono);
		line-height: 1.3;
	}

	@media (max-width: 760px) {
		.fingerprint-topbar,
		.selector-bar,
		.custom-tools {
			align-items: stretch;
			flex-direction: column;
		}

		.fingerprint-topbar > .field,
		.selector-bar .field,
		.chart-card,
		.custom-option {
			width: 100%;
			min-width: 0;
		}

		.selector-title {
			padding-bottom: 0;
		}

		.selector-controls {
			align-items: stretch;
			flex-wrap: wrap;
			justify-content: flex-start;
		}
	}
</style>

<script id="fingerprint-data" type="application/json" set:html={JSON.stringify(fingerprints)}></script>

<script>
	import { CustomChart, LineChart } from 'echarts/charts';
	import { GridComponent, TooltipComponent } from 'echarts/components';
	import * as echarts from 'echarts/core';
	import { SVGRenderer } from 'echarts/renderers';

	echarts.use([LineChart, CustomChart, GridComponent, TooltipComponent, SVGRenderer]);

	const fingerprints = JSON.parse(document.getElementById('fingerprint-data').textContent);
	const root = document.querySelector('[data-fingerprint-root]');
	const fingerprintSelect = root?.querySelector('[data-fingerprint-select]');
	const setSelect = root?.querySelector('[data-parameter-set-select]');
	const customEdit = root?.querySelector('[data-custom-edit]');
	const customModal = root?.querySelector('[data-custom-modal]');
	const customClose = root?.querySelector('[data-custom-close]');
	const customFilter = root?.querySelector('[data-custom-filter]');
	const customList = root?.querySelector('[data-custom-list]');
	const customSelectVisible = root?.querySelector('[data-custom-select-visible]');
	const customClear = root?.querySelector('[data-custom-clear]');
	const customApply = root?.querySelector('[data-custom-apply]');
	const customNames = new Set();
	const ratioScales = {
		update_grad_norm_ratio: 'log',
		update_theta_norm_ratio: 'log',
	};
	const chartInstances = new Map();

	const metricInfo = {
		update_neg_grad_cos: {
			title: 'Gradient alignment',
			subtitle: 'mean cos(update, -grad) · update_neg_grad_cos',
		},
		update_prev_update_cos: {
			title: 'Update consistency',
			subtitle: 'mean cos(update_t, update_t-1) · update_prev_update_cos',
		},
		update_grad_norm_ratio: {
			title: 'Update / gradient',
			subtitle: 'mean ||update|| / ||grad|| · update_grad_norm_ratio',
		},
		update_theta_norm_ratio: {
			title: 'Update / weights',
			subtitle: 'mean ||update|| / ||theta|| · update_theta_norm_ratio',
		},
	};
	const metrics = Object.keys(metricInfo);
	const ratioMetrics = new Set(['update_grad_norm_ratio', 'update_theta_norm_ratio']);
	const format = (value) => {
		if (!Number.isFinite(value)) return 'n/a';
		const abs = Math.abs(value);
		if (abs !== 0 && (abs < 0.01 || abs >= 10000)) return value.toExponential(2);
		return value.toLocaleString('en-US', { maximumFractionDigits: 6 });
	};
	const selectedFingerprint = () => fingerprints[Number(fingerprintSelect?.value ?? 0)]?.full;

	function render() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return;
		ensureCustomSelection(fingerprint);
		renderMeta(fingerprint);
		renderSetSummary(fingerprint);
		renderCharts(fingerprint);
	}

	function renderMeta(fingerprint) {
		root.querySelector('[data-run-meta]').replaceChildren(
			...[
				fingerprint.optimizer.name,
				fingerprint.task.id,
				fingerprint.model.id,
				`seed ${fingerprint.task.seed}`,
				`${fingerprint.snapshots.length} snapshots`,
				`${fingerprint.snapshots[0].parameters.length} params`,
			].map((text) => {
				const span = document.createElement('span');
				span.textContent = text;
				return span;
			}),
		);
	}

	function ensureCustomSelection(fingerprint) {
		if (customNames.size > 0) return;
		for (const name of depthProbeNames(fingerprint)) customNames.add(name);
	}

	function depthProbeNames(fingerprint) {
		const available = new Set(fingerprint.snapshots[0].parameters.map((parameter) => parameter.name));
		return ['conv1.weight', 'layer1.0.conv1.weight', 'layer2.0.conv1.weight', 'layer3.0.conv1.weight', 'layer4.0.conv1.weight', 'fc.weight'].filter(
			(name) => available.has(name),
		);
	}

	function selectedParameters(fingerprint) {
		const params = fingerprint.snapshots[0].parameters;
		const set = setSelect?.value ?? 'conv_weights';
		if (set === 'custom') return params.filter((parameter) => customNames.has(parameter.name));
		const predicates = {
			conv_weights: (parameter) => parameter.name.includes('conv') && parameter.name.endsWith('.weight'),
			conv_biases: (parameter) => parameter.name.includes('conv') && parameter.name.endsWith('.bias'),
			batchnorm_weights: (parameter) => parameter.name.includes('bn') && parameter.name.endsWith('.weight'),
			batchnorm_biases: (parameter) => parameter.name.includes('bn') && parameter.name.endsWith('.bias'),
			all_weights: (parameter) => parameter.name.endsWith('.weight'),
			all_biases: (parameter) => parameter.name.endsWith('.bias'),
			layer1: (parameter) => parameter.name.startsWith('layer1'),
			layer2: (parameter) => parameter.name.startsWith('layer2'),
			layer3: (parameter) => parameter.name.startsWith('layer3'),
			layer4: (parameter) => parameter.name.startsWith('layer4'),
			downsample: (parameter) => parameter.name.includes('downsample'),
			fc: (parameter) => parameter.name.startsWith('fc'),
		};
		return params.filter(predicates[set] ?? (() => false));
	}

	function renderSetSummary(fingerprint) {
		const params = selectedParameters(fingerprint);
		root.querySelector('[data-set-summary]').textContent = `Averaging ${params.length} parameter${params.length === 1 ? '' : 's'}.`;
	}

	function averagedSeries(fingerprint, metric) {
		const names = new Set(selectedParameters(fingerprint).map((parameter) => parameter.name));
		return fingerprint.snapshots.map((snapshot) => {
			const values = snapshot.parameters
				.filter((parameter) => names.has(parameter.name))
				.map((parameter) => parameter.metrics[metric])
				.filter((value) => Number.isFinite(value));
			const mean = values.length ? values.reduce((sum, value) => sum + value, 0) / values.length : null;
			const variance = values.length ? values.reduce((sum, value) => sum + (value - mean) ** 2, 0) / values.length : 0;
			const std = Math.sqrt(variance);
			return {
				step: snapshot.step,
				value: mean,
				low: values.length ? mean - std : null,
				high: values.length ? mean + std : null,
				count: values.length,
			};
		});
	}

	function renderCharts(fingerprint) {
		for (const chart of chartInstances.values()) chart.dispose();
		chartInstances.clear();
		const chartSpecs = metrics.map((metric) => {
			const article = document.createElement('article');
			article.className = 'chart-card';
			const header = document.createElement('header');
			const titleWrap = document.createElement('div');
				const title = document.createElement('h3');
				title.textContent = metricInfo[metric].title;
				const subtitle = document.createElement('div');
				subtitle.className = 'chart-subtitle';
				subtitle.textContent = metricInfo[metric].subtitle;
			titleWrap.append(title, subtitle);
			header.append(titleWrap);
			if (ratioMetrics.has(metric)) header.append(makeScaleToggle(metric));
			const host = document.createElement('div');
			host.className = 'main-chart';
			const chartRoot = document.createElement('div');
			host.append(chartRoot);
			const note = document.createElement('div');
			note.className = 'chart-note';
			article.append(header, host, note);
			return { article, chartRoot, note, metric };
		});
		root.querySelector('[data-chart-stack]').replaceChildren(...chartSpecs.map((spec) => spec.article));
		for (const spec of chartSpecs) {
			renderLineChart(spec.chartRoot, spec.note, averagedSeries(fingerprint, spec.metric), spec.metric);
		}
	}

	function makeScaleToggle(metric) {
		const wrap = document.createElement('div');
		wrap.className = 'scale-toggle';
		for (const scale of ['log', 'linear']) {
			const button = document.createElement('button');
			button.type = 'button';
			button.textContent = scale;
			button.setAttribute('aria-pressed', String(ratioScales[metric] === scale));
			button.addEventListener('click', () => {
				ratioScales[metric] = scale;
				const fingerprint = selectedFingerprint();
				if (fingerprint) renderCharts(fingerprint);
			});
			wrap.append(button);
		}
		return wrap;
	}

	function renderLineChart(host, note, points, metric) {
		const cosineMetric = metric === 'update_neg_grad_cos' || metric === 'update_prev_update_cos';
		const logScale = ratioMetrics.has(metric) && ratioScales[metric] === 'log';
		const transformed = points
			.map((point) => ({
				step: point.step,
				rawValue: point.value,
				value: logScale && Number.isFinite(point.value) && point.value > 0 ? Math.log10(point.value) : point.value,
				low:
					logScale && Number.isFinite(point.low) && point.low > 0
						? Math.log10(point.low)
						: !logScale
							? point.low
							: null,
				high:
					logScale && Number.isFinite(point.high) && point.high > 0
						? Math.log10(point.high)
						: !logScale
							? point.high
							: null,
				count: point.count,
			}))
			.filter((point) => Number.isFinite(point.value) && (!logScale || point.rawValue > 0));
		const missing = points.filter((point) => !point.count).length;
		note.textContent = missing ? `${missing} snapshot${missing === 1 ? '' : 's'} had no finite values for this group and metric.` : '';
		const chart = echarts.init(host, null, { renderer: 'svg' });
		chartInstances.set(host, chart);
		const steps = transformed.map((point) => point.step);
		const xMin = steps.length ? Math.min(...steps) : 0;
		const xMax = steps.length ? Math.max(...steps) : 1;
		const xInterval = Math.max(Math.round((xMax - xMin) / 300) * 100, 100);
		const meanData = transformed.map((point) => [point.step, point.value, point.rawValue, point.count]);
		const bandPoints = transformed.filter((point) => Number.isFinite(point.low) && Number.isFinite(point.high));
		const bandValues = transformed.flatMap((point) => [point.low, point.high]).filter((value) => Number.isFinite(value));
		const dataMax = transformed.length ? Math.max(...transformed.map((point) => point.value), ...bandValues) : 1;
		const dataMin = transformed.length ? Math.min(...transformed.map((point) => point.value), ...bandValues) : 0;
		const yMin = cosineMetric ? -1.05 : logScale ? Math.floor(dataMin) : 0;
		const yMax = cosineMetric
			? 1.05
			: logScale
				? Math.max(Math.ceil(dataMax + 0.12), Math.floor(dataMin) + 1)
				: Math.max(dataMax * 1.18, dataMax + 1e-12);
		chart.setOption({
			animation: false,
			color: ['#7b2d26'],
			grid: { left: 54, right: 16, top: 24, bottom: 34 },
			tooltip: {
				trigger: 'axis',
				confine: true,
				axisPointer: { type: 'line', lineStyle: { color: '#bfb4a4' } },
				formatter: (items) => {
					const mean = items.find((item) => item.seriesName === 'mean');
					if (!mean) return '';
					const raw = mean.data?.[2] ?? mean.data?.[1];
					const count = mean.data?.[3];
					return `step ${mean.data[0]}<br/>mean: ${format(raw)}${count ? `<br/>n: ${count}` : ''}`;
				},
			},

			xAxis: {
				type: 'value',
				min: xMin,
				max: xMax,
				interval: xInterval,
				splitNumber: 2,
				axisLine: { show: false },
				axisTick: { show: false },
				axisLabel: {
					color: '#6f675c',
					fontFamily: 'IBM Plex Mono, monospace',
					hideOverlap: true,
					formatter: (value) =>
						value > 0 && value % xInterval === 0 ? String(Math.round(value)) : '',
				},
				splitLine: {
					show: true,
					lineStyle: { color: 'rgba(191, 180, 164, 0.35)', width: 1 },
				},
			},

			yAxis: {
				type: 'value',
				min: yMin,
				max: yMax,
				interval: cosineMetric ? 1 : undefined,
				splitNumber: 2,
				boundaryGap: false,

				axisLine: { show: false },
				axisTick: { show: false },
				axisLabel: {
					color: '#6f675c',
					fontFamily: 'IBM Plex Mono, monospace',
					hideOverlap: true,
					formatter: (value) => axisLabel(value, { logScale, cosineMetric }),
				},
				splitLine: {
					show: true,
					lineStyle: { color: 'rgba(191, 180, 164, 0.35)', width: 1 },
				},
			},

			series: [
				...(bandPoints.length > 1
					? [
							{
								name: 'mean ± std',
								type: 'custom',
								data: [0],
								renderItem: (_params, api) => {
									const upper = bandPoints.map((point) => api.coord([point.step, point.high]));
									const lower = [...bandPoints].reverse().map((point) => api.coord([point.step, point.low]));
									return {
										type: 'polygon',
										shape: { points: [...upper, ...lower] },
										style: { fill: '#7b2d26', opacity: 0.14 },
									};
								},
								silent: true,
								z: 1,
							},
						]
					: []),

				{
					name: 'mean',
					type: 'line',
					data: meanData,
					symbol: 'circle',
					symbolSize: 4,
					lineStyle: { color: '#7b2d26', width: 2 },
					itemStyle: { color: '#7b2d26' },
					z: 2,
				},
			],
		});
	}

	function axisLabel(value, { logScale, cosineMetric }) {
		if (cosineMetric) {
			for (const tick of [-1, 0, 1]) {
				if (Math.abs(value - tick) < 0.08) return formatSigFig(tick);
			}
			return '';
		}
		if (logScale) return formatSigFig(10 ** value);
		return formatSigFig(value);
	}

	function formatSigFig(value) {
		if (!Number.isFinite(value)) return 'n/a';
		if (value === 0) return '0';
		const abs = Math.abs(value);
		if (abs < 0.01 || abs >= 10000) return value.toExponential(1);
		return Number(value.toPrecision(2)).toString();
	}

	function openCustomModal() {
		setSelect.value = 'custom';
		renderCustomList();
		customModal.setAttribute('aria-hidden', 'false');
	}

	function closeCustomModal() {
		customModal.setAttribute('aria-hidden', 'true');
	}

	function visibleCustomParameters() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return [];
		const filter = String(customFilter?.value ?? '').trim().toLowerCase();
		return fingerprint.snapshots[0].parameters.filter((parameter) => !filter || parameter.name.toLowerCase().includes(filter));
	}

	function renderCustomList() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return;
		const visible = visibleCustomParameters();
		customList.replaceChildren(
			...visible.map((parameter) => {
				const label = document.createElement('label');
				label.className = 'custom-option';
				const checkbox = document.createElement('input');
				checkbox.type = 'checkbox';
				checkbox.value = parameter.name;
				checkbox.checked = customNames.has(parameter.name);
				checkbox.addEventListener('change', () => {
					if (checkbox.checked) customNames.add(parameter.name);
					else customNames.delete(parameter.name);
					renderCustomCount();
				});
				const span = document.createElement('span');
				span.textContent = parameter.name;
				label.append(checkbox, span);
				return label;
			}),
		);
		renderCustomCount();
	}

	function renderCustomCount() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return;
		root.querySelector('[data-custom-count]').textContent =
			`${customNames.size} selected / ${visibleCustomParameters().length} visible / ${fingerprint.snapshots[0].parameters.length} total`;
	}

	fingerprintSelect?.addEventListener('change', () => {
		customNames.clear();
		render();
	});
	setSelect?.addEventListener('change', () => {
		if (setSelect.value === 'custom') openCustomModal();
		render();
	});
	customEdit?.addEventListener('click', openCustomModal);
	customClose?.addEventListener('click', closeCustomModal);
	customModal?.addEventListener('click', (event) => {
		if (event.target === customModal) closeCustomModal();
	});
	customFilter?.addEventListener('input', renderCustomList);
	customSelectVisible?.addEventListener('click', () => {
		for (const parameter of visibleCustomParameters()) customNames.add(parameter.name);
		renderCustomList();
	});
	customClear?.addEventListener('click', () => {
		customNames.clear();
		renderCustomList();
	});
	customApply?.addEventListener('click', () => {
		closeCustomModal();
		render();
	});
	window.addEventListener('resize', () => {
		for (const chart of chartInstances.values()) chart.resize();
	});
	render();
</script>
