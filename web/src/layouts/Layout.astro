---
interface Props {
	title?: string;
	wide?: boolean;
}

const { title = 'NanoGPT traces', wide = false } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${basePath}${path}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase('/logo.svg')} />
		<link rel="icon" href={withBase('/logo.svg')} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class:list={['site-header', { 'is-wide': wide }]}>
			<a class="wordmark" href={withBase('/')}>
				<img src={withBase('/logo.svg')} alt="" width="48" height="48" />
				<span>optimizer fingerprints</span>
			</a>
			<div class="site-actions">
				<a class="header-link blog-link" href="https://www.sarthakmangla.com/blog" target="_blank" rel="noreferrer">
					<span>Blog</span>
				</a>
				<a class="header-link blog-link" href="https://github.com/knightron0/fingerprinting" target="_blank" rel="noreferrer" aria-label="GitHub repository">
					<span>GitHub</span>
				</a>
			</div>
		</header>
		<main class:list={{ 'is-wide': wide }}>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap');

	:root {
		color-scheme: light;
		--bg: #fffdf8;
		--paper: #fffffc;
		--ink: #1f1b16;
		--muted: #6f675c;
		--soft: #a79e91;
		--line: #ded6c9;
		--line-strong: #bfb4a4;
		--row: #f8f3e9;
		--accent: #7b2d26;
		--accent-soft: #efe0d6;
		--warn: #8a4b00;
		--measure: 1060px;
		--serif: 'Newsreader', Georgia, 'Times New Roman', serif;
		--sans: 'IBM Plex Sans', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
			'Segoe UI', sans-serif;
		--mono: 'IBM Plex Mono', 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo,
			ui-monospace, monospace;
		font-family: var(--serif);
	}

	html,
	body {
		margin: 0;
		min-width: 320px;
		min-height: 100%;
		background: var(--bg);
		color: var(--ink);
	}

	body {
		font-size: 17px;
		line-height: 1.55;
		text-rendering: optimizeLegibility;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	button,
	select,
	input {
		font-family: var(--sans);
	}

	.site-header {
		display: flex;
		align-items: center;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		max-width: var(--measure);
		margin: 0 auto;
		padding: 22px 28px 16px;
		font-family: var(--sans);
		text-align: center;
	}

	.wordmark {
		display: inline-flex;
		align-items: center;
		flex-direction: column;
		gap: 5px;
		font-family: var(--serif);
		font-size: 30px;
		font-weight: 500;
		letter-spacing: 0;
	}

	.wordmark img {
		width: 48px;
		height: 48px;
		flex: 0 0 auto;
	}

	.site-actions {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
	}

	.header-link {
		display: inline-flex;
		gap: 5px;
		align-items: center;
		min-height: 28px;
		border: 0;
		background: transparent;
		padding: 0px 8px;
		color: var(--muted);
		font-size: 14px;
	}

	.header-link:hover,
	.header-link:focus-visible {
		color: var(--ink);
		outline: 0;
	}

	.github-link {
		padding-right: 4px;
		padding-left: 4px;
	}

	.blog-link {
		padding-right: 2px;
		padding-left: 2px;
	}

	.blog-link:hover,
	.blog-link:focus-visible {
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	main {
		max-width: var(--measure);
		margin: 0 auto;
		padding-bottom: 60px;
	}

	.site-header.is-wide,
	main.is-wide {
		box-sizing: border-box;
		width: 72%;
		max-width: 1900px;
	}

	.site-header.is-wide {
		padding-right: 16px;
		padding-left: 16px;
	}

	@media (max-width: 1200px) {
		.site-header.is-wide,
		main.is-wide {
			width: 100%;
		}
	}

	.page-kicker {
		margin: 0 0 10px;
		color: var(--muted);
		font-family: var(--sans);
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.page-title {
		margin: 0;
		max-width: 780px;
		font-family: var(--serif);
		font-size: clamp(40px, 7vw, 86px);
		font-weight: 500;
		line-height: 0.9;
		letter-spacing: 0;
	}

	.page-copy {
		max-width: 680px;
		margin: 20px 0 0;
		color: var(--muted);
		font-size: 19px;
		line-height: 1.5;
	}

	.page-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 240px;
		gap: 24px;
		align-items: end;
		margin-bottom: 42px;
	}

	.status-line {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 7px;
		max-width: 240px;
		font-family: var(--sans);
	}

	.pill {
		display: inline-flex;
		align-items: center;
		min-height: 22px;
		border: 1px solid var(--line);
		padding: 0 7px;
		background: var(--paper);
		color: var(--muted);
		font-size: 11px;
		white-space: nowrap;
	}

	.section {
		border-top: 1px solid var(--line-strong);
		padding-top: 16px;
		margin-top: 34px;
	}

	.section:first-child {
		margin-top: 0;
	}

	.section-title {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
		margin: 0 0 14px;
		font-family: var(--sans);
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.section-title span {
		color: var(--muted);
		font-size: 11px;
		font-weight: 400;
		text-transform: none;
		letter-spacing: 0;
	}

	.grid-2 {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.field {
		display: grid;
		gap: 6px;
	}

	.field label {
		color: var(--muted);
		font-family: var(--sans);
		font-size: 12px;
	}

	select,
	input[type='search'] {
		width: 100%;
		min-height: 34px;
		border: 1px solid var(--line-strong);
		border-radius: 0;
		background: var(--paper);
		color: var(--ink);
		padding: 6px 8px;
		font-size: 13px;
	}

	select:focus,
	input[type='search']:focus {
		outline: 1px solid var(--ink);
		outline-offset: 0;
	}

	.table-wrap {
		overflow-x: auto;
		border-top: 1px solid var(--line);
	}

	table {
		width: 100%;
		border-collapse: collapse;
		min-width: 720px;
		background: var(--paper);
		font-family: var(--sans);
		font-size: 12px;
		line-height: 1.45;
	}

	th,
	td {
		border-bottom: 1px solid var(--line);
		padding: 8px 9px;
		text-align: left;
		vertical-align: top;
	}

	th {
		color: var(--muted);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	tbody tr:hover {
		background: var(--row);
	}

	.num,
	.mono,
	code,
	pre {
		font-family: var(--mono);
		font-variant-numeric: tabular-nums;
	}

	.num {
		text-align: right;
		white-space: nowrap;
	}

	.muted {
		color: var(--muted);
	}

	.empty {
		border: 1px solid var(--line);
		padding: 22px;
		color: var(--muted);
		background: var(--paper);
		font-size: 18px;
	}

	.pane-shell {
		display: grid;
		gap: 16px;
		padding: 10px 28px 0;
	}

	.pane-frame {
		position: relative;
		padding: 18px;
		border: 1px solid var(--line-strong);
		background: var(--paper);
	}

	.pane-frame::before {
		position: absolute;
		inset: 8px;
		border: 1px solid var(--line);
		content: '';
		pointer-events: none;
	}

	.pane-inner {
		position: relative;
		z-index: 1;
	}

	.pane-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		min-height: 360px;
		border: 1px solid var(--line);
		background: color-mix(in srgb, var(--paper) 92%, white 8%);
	}

	.pane-grid > .pane {
		min-width: 0;
		background: var(--paper);
	}

	.pane-grid > .pane + .pane {
		border-left: 1px solid var(--line-strong);
	}

	.graph-panel {
		position: relative;
		min-height: 260px;
		border: 1px solid var(--line);
		background:
			linear-gradient(var(--line) 1px, transparent 1px),
			linear-gradient(90deg, var(--line) 1px, transparent 1px),
			var(--paper);
		background-size: 48px 48px;
	}

	.graph-panel::before {
		position: absolute;
		inset: 12px;
		border: 1px solid var(--line);
		content: '';
		pointer-events: none;
	}

	.graph-panel::after {
		position: absolute;
		right: 18px;
		bottom: 18px;
		left: 18px;
		height: 1px;
		background: var(--line-strong);
		content: '';
		pointer-events: none;
	}

	.stat-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
		background: var(--paper);
	}

	.stat {
		min-width: 0;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: 12px;
	}

	.stat-label {
		margin-bottom: 8px;
		color: var(--muted);
		font-family: var(--sans);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.stat-value {
		font-size: 20px;
		line-height: 1;
	}

	.metric-bar {
		display: grid;
		grid-template-columns: minmax(44px, 90px) minmax(96px, 1fr);
		align-items: center;
		gap: 10px;
	}

	.bar-track {
		height: 4px;
		background: #e8dfd2;
	}

	.bar-fill {
		width: var(--w, 0%);
		height: 100%;
		background: var(--accent);
	}

	details {
		padding: 10px 0;
		font-family: var(--sans);
	}

	summary {
		cursor: pointer;
		color: var(--muted);
	}

	pre {
		overflow-x: auto;
		margin: 12px 0 0;
		padding: 12px;
		background: #fbf7ee;
		border: 1px solid var(--line);
		font-size: 12px;
		line-height: 1.5;
	}

	@media (max-width: 760px) {
		.site-header,
		.page-head,
		.grid-2 {
			grid-template-columns: 1fr;
		}

		.site-header {
			align-items: center;
			flex-direction: column;
			gap: 4px;
		}

		.status-line {
			justify-content: flex-start;
		}

		.stat-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.pane-shell {
			padding-inline: 16px;
		}

		.pane-frame {
			padding: 14px;
		}

		.pane-grid {
			grid-template-columns: 1fr;
		}

		.pane-grid > .pane + .pane {
			border-top: 1px solid var(--line-strong);
			border-left: 0;
		}
	}

	@media (max-width: 480px) {
		main {
			padding-inline: 16px;
		}

		.site-header {
			padding-inline: 16px;
		}

		nav {
			width: 100%;
			justify-content: space-between;
			gap: 8px;
		}

		nav a {
			padding-inline: 6px;
		}

		.page-title {
			font-size: 42px;
		}

		.page-copy {
			font-size: 17px;
		}

		.stat-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
